      "notes": "Polls upload_completion_queue via v_upload_completion_pending view every 30s. Same cadence as Workflow 9 (verification dispatcher)."
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Claim up to 25 pending rows with FOR UPDATE SKIP LOCKED.\n-- Increments attempts atomically. View handles join to sub/GC context.\nWITH claimed AS (\n  SELECT q.id\n  FROM upload_completion_queue q\n  WHERE (q.slack_dispatched_at IS NULL OR q.confirmation_dispatched_at IS NULL)\n    AND q.attempts < 5\n  ORDER BY q.created_at ASC\n  LIMIT 25\n  FOR UPDATE SKIP LOCKED\n)\nUPDATE upload_completion_queue q\nSET attempts = attempts + 1\nFROM claimed\nWHERE q.id = claimed.id\nRETURNING q.id;",
        "options": {}
      },
      "id": "a524cf98-8628-4156-95e5-dd32cc376398",
      "name": "02 · Postgres · Claim Pending Uploads",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -1600,
        112
      ],
      "credentials": {
        "postgres": {
          "id": "egOLTpUjmoIDA785",
          "name": "supabase-postgres"
        }
      },
      "notes": "Claim step. Atomic increment + lock. Returns 0 rows when queue is empty (short-circuits downstream)."
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Pull full context for the claimed row from the view.\nSELECT * FROM v_upload_completion_pending\nWHERE queue_id = NULLIF($1, 'null')::uuid;",
        "options": {
          "queryReplacement": "={{ $json.id }}"
        }
      },
