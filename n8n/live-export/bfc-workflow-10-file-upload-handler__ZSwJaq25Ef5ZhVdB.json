"width:100%;background:#F6FAEC;border-left:3px solid #B8E532;border-radius:0 4px 4px 0;\"><tr><td style=\"padding:14px 16px;font-family:'Courier New',monospace;font-size:9.5pt;color:#07080B;\">Document: {{ $json.document_label }}<br/>Uploaded: {{ new Date($node['03 · Postgres · Fetch Context'].json.uploaded_at).toUTCString() }}<br/>Reference: {{ $node['03 · Postgres · Fetch Context'].json.token }}</td></tr></table></td></tr><tr><td style=\"background:#F6FAEC;padding:18px 28px;border-top:1px solid #ECEFF3;font-family:'Courier New',monospace;font-size:8.5pt;color:#5E7B1F;text-transform:uppercase;letter-spacing:0.14em;\">Blackflowcode.ai &middot; hello@blackflowcodeai.com &middot; 516.604.1804</td></tr></table></td></tr></table></body></html>",
              "type": "string"
