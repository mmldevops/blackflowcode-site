{
  "name": "BFC - Workflow 2 - Procore Switcher Finder",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * 1"
            }
          ]
        }
      },
      "id": "node-cron-procore",
      "name": "Every Monday 9 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.id AS sub_id, s.company_name, s.trade_type, s.city, s.state, s.contact_email, s.contact_phone, g.company_name AS gc_name, gsr.procore_connected, gsr.last_worked FROM gc_subcontractor_relationships gsr JOIN subcontractors s ON s.id = gsr.subcontractor_id JOIN gc_companies g ON g.id = gsr.gc_id WHERE gsr.procore_connected = false AND gsr.total_contract_value > 50000 AND gsr.status = 'active' ORDER BY gsr.total_contract_value DESC LIMIT 20",
        "options": {}
      },
      "id": "node-pg-procore",
      "name": "Find Non-Procore Subs",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        460,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "egOLTpUjmoIDA785",
          "name": "supabase-postgres"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-has-subs",
              "leftValue": "={{ $json.company_name }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "node-if-procore",
      "name": "Has Switchers?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const d = item.json;\n  \n  // Calculate switcher score based on contract value and activity\n  let score = 5; // base score for Procore non-users\n  \n  results.push({\n    json: {\n      company_name: d.company_name,\n      trade_type: d.trade_type,\n      city: d.city,\n      state: d.state,\n      contact_email: d.contact_email || '',\n      contact_phone: d.contact_phone || '',\n      gc_name: d.gc_name,\n      procore_connected: d.procore_connected,\n      last_worked: d.last_worked,\n      switcher_score: score,\n      source: 'Procore Switcher',\n      status: 'New',\n      sub_id: d.sub_id,\n      week_of: new Date().toISOString().split('T')[0]\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "node-code-procore",
      "name": "Score Switchers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        240
      ]
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "create",
        "databaseId": {
          "__rl": true,
          "value": "341d9016-ebd2-4b4a-99e8-f7713c27bb58",
          "mode": "id"
        },
        "title": "={{ $json.company_name }}",
        "propertiesUi": {
          "propertyValues": [
            {
              "key": "Source",
              "type": "select",
              "selectValue": "Switcher"
            },
            {
              "key": "Status",
              "type": "select",
              "selectValue": "New"
            },
            {
              "key": "Urgency",
              "type": "number",
              "numberValue": "={{ $json.switcher_score }}"
            },
            {
              "key": "Trade Type",
