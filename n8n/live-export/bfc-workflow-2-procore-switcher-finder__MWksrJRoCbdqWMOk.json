            },
            {
              "key": "Contact Email",
              "type": "richText",
              "textValue": "={{ $json.contact_email }}"
            },
            {
              "key": "Supabase ID",
              "type": "richText",
              "textValue": "={{ $json.sub_id }}"
            }
          ]
        }
      },
      "id": "node-notion-procore",
      "name": "Add Switchers to Notion",
