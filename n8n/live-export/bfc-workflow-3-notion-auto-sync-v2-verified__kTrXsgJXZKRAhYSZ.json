      ],
      "credentials": {
        "notionApi": {
          "id": "70qG4MthaFmLBKJa",
          "name": "Notion SalesLead DB"
        }
      },
      "notes": "Returns ALL pages in the Sales Leads DB. The Classify node filters in code to Source=Supabase Sync. Avoids brittle Notion API filter syntax."
    },
    {
      "parameters": {
        "jsCode": "// Get source rows from Bundle node\nconst sourceRows = $('Bundle Source Rows').first().json.source_rows;\n\n// Get existing Notion rows from previous node  \nconst notionPages = $input.all();\n\n// Build dedup map — handles both n8n flat format AND raw Notion API nested format\nconst notionMap = new Map();\n\nfor (const item of notionPages) {\n  const data = item.json;\n  \n  const sourceVal = data.Source?.select?.name \n                 ?? data.Source \n                 ?? data.properties?.Source?.select?.name;\n  \n  if (sourceVal !== 'Supabase Sync') continue;\n  \n  const supId = data['Supabase ID']?.rich_text?.[0]?.plain_text\n             ?? data['Supabase ID']\n             ?? data.properties?.['Supabase ID']?.rich_text?.[0]?.plain_text;\n  \n  if (!supId) continue;\n  \n  notionMap.set(String(supId).trim(), {\n    pageId: data.id || data.url\n  });\n}\n\nconsole.log(`Notion dedup map: ${notionMap.size} existing Supabase Sync rows found`);\nconsole.log('Map keys:', [...notionMap.keys()]);\nconsole.log(`Source rows from Supabase: ${sourceRows.length}`);\n\n// Classify each source row\nconst classified = sourceRows.map(row => {\n  const supId = String(row.supabase_id).trim();\n  const existing = notionMap.get(supId);\n  \n  return {\n    json: {\n      op: existing ? 'update' : 'create',\n      notion_page_id: existing?.pageId || null,\n      supabase_id: supId,\n      company_name: row.company_name || 'Unknown',\n      trade_type: row.trade_type || '',\n      alert_level: Number(row.alert_level) || 1,\n      violation_count: Number(row.violation_count) || 0,\n      urgency: Number(row.urgency) || 0,\n      compliance_tier: row.compliance_tier || 'standard',\n      total_fines: Number(row.total_fines) || 0,\n      last_violation_date: row.last_violation_date || null,\n      gc_name: row.gc_name || '',\n      location: row.location || '',\n      trigger_reason: row.trigger_reason || 'No active trigger',\n      contact_email: row.contact_email || '',\n      synced_at: new Date().toISOString().split('T')[0]\n    }\n  };\n});\n\nconst creates = classified.filter(c => c.json.op === 'create').length;\nconst updates = classified.filter(c => c.json.op === 'update').length;\nconsole.log(`Classified: ${creates} CREATE, ${updates} UPDATE`);\n\nreturn classified;"
      },
