      "parameters": {
        "jsCode": "// Aggregate all Postgres rows into a single item so downstream Notion fetch runs ONCE.\nconst rows = $input.all().map(i => i.json);\nreturn [{ json: { source_rows: rows, source_count: rows.length } }];"
