      ],
      "credentials": {
        "slackOAuth2Api": {
          "id": "5hkIvm7alWjzpl3O",
          "name": "Slack account"
        }
      },
      "webhookId": "7eccfdc6-4fac-4a12-baad-279a7ac094fe"
    },
    {
