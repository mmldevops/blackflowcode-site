        "httpHeaderAuth": {
          "id": "4nRJASvFJd3fXLqZ",
          "name": "supabase-service-role"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const linkResponse = $input.first().json;\nconst magicLink = linkResponse.action_link || linkResponse.properties?.action_link || '';\nconst expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();\n\nreturn [{\n  json: {\n    magic_link: magicLink,\n    magic_link_expires_at: expiresAt,\n    client_email: $vars.client_email || 'hello@blackflowcode.ai',\n    client_id: $vars.client_id || 'acme-gc-001',\n    report_month: new Date().toISOString().substring(0, 7) + '-01',\n    report_url: 'https://reports.blackflowcodeai.com/construction-compliance'\n  }\n}];"
      },
