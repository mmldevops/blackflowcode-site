        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"magiclink\",\n  \"email\": \"{{ $vars.client_email || 'hello@blackflowcode.ai' }}\",\n  \"options\": {\n    \"redirectTo\": \"https://reports.blackflowcodeai.com/construction-compliance\"\n  }\n}",
