      "parameters": {
        "sendTo": "={{ $json.client_email }}",
        "subject": "=Your {{ $now.toFormat('MMMM yyyy') }} Compliance Report — blackflowcode.ai",
        "emailType": "html",
        "message": "=<div style=\"font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #07080B; color: #ffffff; padding: 40px;\">\n\n<div style=\"margin-bottom: 32px;\">\n  <span style=\"font-family: monospace; font-size: 11px; letter-spacing: 0.12em; color: #D4A843; text-transform: uppercase;\">blackflowcode.ai</span>\n</div>\n\n<h1 style=\"font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #ffffff;\">Your {{ $now.toFormat('MMMM yyyy') }} Compliance Report is Ready</h1>\n\n<p style=\"color: #8896AA; line-height: 1.7; margin-bottom: 28px;\">Your monthly subcontractor compliance report has been generated and is ready for review. Click the button below to access your secure, personalized report.</p>\n\n<div style=\"margin-bottom: 32px;\">\n  <a href=\"{{ $json.magic_link }}\" style=\"display: inline-block; background: #D4A843; color: #07080B; padding: 14px 28px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 0.06em;\">VIEW YOUR REPORT →</a>\n</div>\n\n<p style=\"color: #4D5B6E; font-size: 12px; font-family: monospace;\">This link expires in 24 hours. If you need a new link, contact hello@blackflowcode.ai</p>\n\n<hr style=\"border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 32px 0;\" />\n\n<p style=\"color: #4D5B6E; font-size: 12px;\">Neno Gaspard · blackflowcode.ai · hello@blackflowcode.ai</p>\n\n</div>",
        "options": {
          "attachmentsUi": {
            "attachmentsBinary": [
              {}
            ]
          },
          "fromName": "Neno at blackflowcode.ai"
        }
      },
